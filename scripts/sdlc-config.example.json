{
  "projectPath": "/path/to/your/project",
  "pluginsPath": "/path/to/nmg-plugins",
  "model": "opus",
  "effort": "high",
  "logDir": "",
  "maxLogDiskUsageMB": 500,
  "_cleanup_note": "processPatterns is a Phase 2 fallback; Phase 1 uses the Claude subprocess PID tree",
  "_draft_issue_note": "draft-issue is interactive-only as of plugin v6.0.0 (issue #116); do not add a draftIssue step",
  "cleanup": {
    "processPatterns": ["--remote-debugging-port"]
  },
  "steps": {
    "startCycle":   { "maxTurns": 5,   "timeoutMin": 5  },
    "startIssue":   { "maxTurns": 15,  "timeoutMin": 5,  "skill": "start-issue",        "model": "sonnet" },
    "writeSpecs":   { "maxTurns": 40,  "timeoutMin": 15, "skill": "write-spec",           "model": "opus",   "effort": "high" },
    "implement":    { "maxTurns": 100, "timeoutMin": 30, "skill": "write-code", "model": "opus",   "effort": "medium" },
    "verify":       { "maxTurns": 60,  "timeoutMin": 20, "skill": "verify-code",         "model": "sonnet", "effort": "high" },
    "commitPush":   { "maxTurns": 10,  "timeoutMin": 5,                                      "model": "sonnet" },
    "createPR":     { "maxTurns": 30,  "timeoutMin": 5,  "skill": "open-pr",            "model": "sonnet" },
    "monitorCI":    { "maxTurns": 40,  "timeoutMin": 20,                                     "model": "sonnet" },
    "merge":        { "maxTurns": 5,   "timeoutMin": 5,                                      "model": "sonnet" }
  },
  "maxRetriesPerStep": 3,
  "maxBounceRetries": 3
}
